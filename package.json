{
  "name": "conquer-overlay",
  "version": "1.0.0",
  "description": "Classic Conquer Online - Market Overlay",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:admin": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$project = (Resolve-Path '.').Path; $electron = (Resolve-Path '.\\node_modules\\electron\\dist\\electron.exe').Path; Start-Process -Verb RunAs -FilePath $electron -ArgumentList @($project) -WorkingDirectory $project\"",
    "dev": "electron . --dev",
    "dev:admin": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$project = (Resolve-Path '.').Path; $electron = (Resolve-Path '.\\node_modules\\electron\\dist\\electron.exe').Path; Start-Process -Verb RunAs -FilePath $electron -ArgumentList @($project, '--dev') -WorkingDirectory $project\"",
    "build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^12.8.0",
    "node-cron": "^4.2.1",
    "screenshot-desktop": "^1.12.7",
    "tesseract.js": "^5.0.4",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.classicconquer.overlay",
    "productName": "Conquer Overlay",
    "win": {
      "requestedExecutionLevel": "requireAdministrator",
      "target": "nsis"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "public/**/*"
    ]
  }
}
